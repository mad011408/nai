# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# NVIDIA API Configuration
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_HOST=https://integrate.api.nvidia.com
NVIDIA_API_PATH=/v1/chat/completions
NVIDIA_DEFAULT_MODEL=deepseek-ai/deepseek-v3.1

# SambaNova API Configuration
SAMBANOVA_API_KEY=your_sambanova_api_key_here
SAMBANOVA_API_HOST=https://api.sambanova.ai
SAMBANOVA_API_PATH=/v1/chat/completions
SAMBANOVA_DEFAULT_MODEL=DeepSeek-V3.1

# Cerebras API Configuration
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_API_HOST=https://api.cerebras.ai
CEREBRAS_API_PATH=/v1/chat/completions
CEREBRAS_DEFAULT_MODEL=qwen-3-coder-480b

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/advanced-ai-agent
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Performance Settings
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30000
BATCH_SIZE=10

# Security
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Model Settings
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
DEFAULT_TOP_P=0.9

# Agent Configuration
ENABLE_REASONING=true
ENABLE_PLANNING=true
ENABLE_LEARNING=true
MAX_REASONING_DEPTH=5
